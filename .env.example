# SafraPay — segredos (TEMPLATE). Copie para `.env` e preencha; `.env` é git-ignored.
# Origem dos valores: Portal do desenvolvedor > Gerenciamento > "Chaves de Acesso".
# Autenticação: POST {SAFRA_ENDPOINT_GATEWAY}/v2/merchant/auth
#   header  Authorization: <SAFRA_MERCHANT_TOKEN>   -> retorna accessToken (JWT ~30min)

# "Merchant Token" (Chaves de Acesso) — chave de acesso à API
SAFRA_MERCHANT_TOKEN=
# "ID" (Chaves de Acesso) = merchantId (GUID do estabelecimento)
SAFRA_MERCHANT_ID=
# "Código de Ativação" (Chaves de Acesso)
SAFRA_CODIGO_ATIVACAO=
# CNPJ do estabelecimento (usado no BCrypt de auth: CNPJ + Merchant Token)
SAFRA_CNPJ=
# Código da loja / EC
SAFRA_CODIGO_LOJA=
