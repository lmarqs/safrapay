# SafraPay — Produção (URLs por ambiente; sem segredo; versionável).
# Carregue junto com `.env` (segredos). Requer SAFRA_MERCHANT_TOKEN de produção
# (o token exibido no portal de homologação não vale em produção).
SAFRA_ENDPOINT_GATEWAY=https://payment.safrapay.com.br
SAFRA_ENDPOINT_WEBHOOK=https://webhook.safrapay.com.br
SAFRA_ENDPOINT_PORTAL=https://portal-api.safrapay.com.br
